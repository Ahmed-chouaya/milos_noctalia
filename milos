#!/usr/bin/env bash
set -euo pipefail

# milos_niri - NixOS TUI Installer
# Usage: ./milos
#
# Detects current hostname, generates NixOS configs, and applies them.
# Everything handled automatically - just run from the cloned directory.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BINARY="$SCRIPT_DIR/target/release/milos_niri"

# Detect current hostname
HOSTNAME=$(cat /etc/hostname)
echo "══════════════════════════════════════════════════════════════"
echo "  MILOS - NixOS TUI Installer"
echo "══════════════════════════════════════════════════════════════"
echo ""
echo "  Detected hostname: $HOSTNAME"
echo ""

# Build if needed
if [[ ! -f "$BINARY" ]]; then
    echo "Building milos_niri..."
    echo ""
    echo "  Note: First build downloads ~500MB (cached for next time)"
    echo ""

    nix-shell -p cargo rustc rustfmt git --run "
        cd '$SCRIPT_DIR'
        cargo build --release
    "

    echo ""
    echo "✓ Build complete"
    echo ""
fi

# Run the installer
cd "$SCRIPT_DIR"
"$BINARY"
