#!/usr/bin/env bash
set -euo pipefail

# milos_niri - NixOS TUI Installer
# Usage: ./milos [nixos-config-dir]
#
# If nixos-config-dir is provided, runs installer from that directory.
# Otherwise, prompts user to navigate to their NixOS config with flake.nix.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BINARY="$SCRIPT_DIR/target/release/milos_niri"
SOURCE_DIR="$SCRIPT_DIR"

# Determine target directory
if [[ -n "${1:-}" ]]; then
    TARGET_DIR="$1"
else
    echo "══════════════════════════════════════════════════════════════"
    echo "  MILOS - NixOS TUI Installer"
    echo "══════════════════════════════════════════════════════════════"
    echo ""
    echo "No directory specified. Please navigate to your NixOS config"
    echo "directory (the one containing flake.nix) before running."
    echo ""
    echo "Example: ./milos /etc/nixos"
    echo ""
    read -rp "Path to your NixOS config directory: " TARGET_DIR
fi

# Validate target directory
if [[ ! -d "$TARGET_DIR" ]]; then
    echo "Error: Directory does not exist: $TARGET_DIR"
    exit 1
fi

if [[ ! -f "$TARGET_DIR/flake.nix" ]]; then
    echo "Error: No flake.nix found in $TARGET_DIR"
    echo "The installer must run from a directory containing flake.nix"
    exit 1
fi

# Build if needed
if [[ ! -f "$BINARY" ]] || [[ "$SOURCE_DIR/src" -nt "$BINARY" ]]; then
    echo "══════════════════════════════════════════════════════════════"
    echo "  Building milos_niri..."
    echo "══════════════════════════════════════════════════════════════"
    echo ""

    nix-shell -p cargo rustc rustfmt git --run "
        cd '$SOURCE_DIR'
        echo 'Compiling...'
        cargo build --release
    "

    echo ""
    echo "✓ Build complete"
    echo ""
fi

# Run the installer
cd "$TARGET_DIR"
echo "══════════════════════════════════════════════════════════════"
echo "  Starting MILOS Installer..."
echo "══════════════════════════════════════════════════════════════"
echo ""
echo "  Target: $TARGET_DIR"
echo ""
"$BINARY"
